{
  "name": "@elsahafy/ui-toolkit-mcp",
  "version": "2.0.1",
  "description": "Full-stack UI toolkit MCP server: generate components, manage design tokens, and audit markup across React, Vue, Svelte, Angular, and Web Components.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ui-toolkit-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ui",
    "component-generator",
    "design-tokens",
    "accessibility",
    "react",
    "vue",
    "svelte",
    "angular",
    "web-components",
    "wcag",
    "design-system",
    "ai-tools",
    "claude",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elsahafy/ui-toolkit-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/elsahafy/ui-toolkit-mcp/issues"
  },
  "homepage": "https://github.com/elsahafy/ui-toolkit-mcp#readme",
  "author": "Ibrahim Elsahafy",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
